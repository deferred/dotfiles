{{- if eq .chezmoi.os "darwin" -}}

#!/usr/bin/env bash

set -euo pipefail
IFS=$'\n\t'

BREWFILE=$(
	cat <<'EOF'
brew "anomalyco/tap/opencode"
brew "asmvik/formulae/skhd"
brew "asmvik/formulae/yabai"
brew "leohenon/tap/ocv"
brew "teamookla/speedtest/speedtest"

brew "go"
brew "node"
brew "python"

brew "jrnl"
brew "opencode"
brew "pam-reattach"
brew "sesh"

cask "1password"
cask "1password-cli"
cask "alacritty"
cask "claude-code"
cask "firefox"
cask "karabiner-elements"
cask "linearmouse"
cask "obsidian"
cask "raycast"
cask "spotify"

cask "font-jetbrains-mono-nerd-font"
EOF
)

# trust each third-party tap referenced by a qualified brew line.
# `|| true` keeps this safe on older Homebrew without `brew trust`.
printf '%s\n' "$BREWFILE" \
	| grep -oE 'brew "[^"]+/[^"]+/' \
	| sed -E 's/brew "(.+)\/$/\1/' | sort -u \
	| while read -r tap; do brew trust --tap "$tap" 2>/dev/null || true; done

printf '%s\n' "$BREWFILE" | brew bundle --file=/dev/stdin

# pin yabai version
if ! brew list --pinned --formula | grep -qx 'yabai'; then
	brew pin yabai
fi

{{ end -}}
